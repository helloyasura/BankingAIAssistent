ENVIRONMENT=development
DEBUG=true
# HS256 requires at least 32 bytes; use JWT_SECRET or JWT_SECRET_KEY
JWT_SECRET=replace-with-a-secret-at-least-32-characters-long
PYTHONPATH=backend
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
PINECONE_API_KEY=
PINECONE_INDEX_NAME=
PINECONE_NAMESPACE=default
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=commercial-bank-ai
HITL_AUTO_APPROVE=true